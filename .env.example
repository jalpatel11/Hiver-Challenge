# Copy to .env and fill in. Only needed for real (non-mock) runs.
# LLM_API_KEY must match whatever provider GEN_MODEL/JUDGE_MODEL points at.
# Switching providers requires setting GEN_MODEL and JUDGE_MODEL to a valid
# LiteLLM model string (e.g., gpt-4o for OpenAI, gemini/gemini-2.0-flash for Gemini).
LLM_API_KEY=your-api-key-here
# Optional overrides (defaults to claude-sonnet-4-6):
# GEN_MODEL=claude-sonnet-4-6
# JUDGE_MODEL=claude-sonnet-4-6
